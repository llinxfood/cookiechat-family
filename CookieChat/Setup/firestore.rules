rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function familyDoc(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId));
    }

    function isFamilyMember(familyId) {
      return isSignedIn() && familyDoc(familyId).data.members[request.auth.uid] != null;
    }

    function isFamilyAdmin(familyId) {
      return isFamilyMember(familyId) && familyDoc(familyId).data.admins[request.auth.uid] == true;
    }

    match /families/{familyId} {
      allow read: if isFamilyMember(familyId);
      allow create: if false;
      allow delete: if false;

      // Solo admins pueden editar perfil de familia/membresias.
      allow update: if isFamilyAdmin(familyId);

      match /rooms/{roomId} {
        allow read: if isFamilyMember(familyId);
        allow create: if false;
        allow delete: if false;
        allow update: if isFamilyAdmin(familyId);

        match /messages/{messageId} {
          allow read: if isFamilyMember(familyId);

          // Cualquier miembro puede escribir solo sus propios mensajes de texto.
          allow create: if isFamilyMember(familyId)
            && request.resource.data.senderId == request.auth.uid
            && request.resource.data.senderRole in ['admin', 'adult', 'child']
            && familyDoc(familyId).data.members[request.auth.uid] == request.resource.data.senderRole
            && request.resource.data.type == 'text'
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 1000
            && request.resource.data.createdAt is timestamp;

          allow update: if false;
          allow delete: if false;
        }
      }
    }
  }
}
